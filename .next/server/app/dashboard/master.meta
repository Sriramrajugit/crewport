{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/dashboard/layout,_N_T_/dashboard/master/layout,_N_T_/dashboard/master/page,_N_T_/dashboard/master"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/dashboard/master/__PAGE__",
    "/dashboard/master",
    "/dashboard",
    "/_index",
    "/_head"
  ]
}