# Database (PostgreSQL - Update with your Vessels DB connection)
DATABASE_URL="postgresql://postgres:admin@localhost:5432/crewport?schema=public"
DIRECT_URL="postgresql://postgres:admin@localhost:5432/crewport"
SHADOW_DATABASE_URL="postgresql://postgres:admin@localhost:5432/crewport_shadow"

# JWT Secret (Change this in production)
JWT_SECRET="your-secret-key-change-this-in-production"

# Session Secret (for iron-session - MUST be at least 32 characters. Change in production!)
SESSION_SECRET="a-very-complex-password-min-32-characters-long-secret-key!@#$"

# Node Environment
NODE_ENV="development"
